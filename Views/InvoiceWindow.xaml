<Window x:Class="KCH_New.Views.InvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="نظام KCH - الفواتير"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Style="{StaticResource MaterialDesignWindow}">

    <materialDesign:DialogHost Identifier="InvoiceDialog">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TopBar -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="FileDocument" Foreground="White"
                                                 Width="28" Height="28" VerticalAlignment="Center"/>
                        <TextBlock Text="نظام إدارة القوائم - KCH"
                                   Foreground="White" FontSize="18" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="10,0"/>
                        <TextBlock x:Name="txtInvoiceNumber" Foreground="White"
                                   FontSize="14" VerticalAlignment="Center"
                                   Margin="20,0" Opacity="0.85"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Foreground="White" ToolTip="البحث"
                                Click="BtnSearch_Click">
                            <materialDesign:PackIcon Kind="Magnify" Width="22" Height="22"/>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Foreground="White" ToolTip="تسجيل خروج"
                                Click="BtnLogout_Click">
                            <materialDesign:PackIcon Kind="Logout" Width="22" Height="22"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Customer Info -->
                <materialDesign:Card Grid.Column="0" Margin="0,0,12,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="بيانات الزبون" FontSize="15" FontWeight="Bold"
                                   Margin="0,0,0,12"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                        <TextBox x:Name="txtCustomerName"
                                 materialDesign:HintAssist.Hint="اسم الزبون *"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,6"/>

                        <TextBox x:Name="txtCustomerAddress"
                                 materialDesign:HintAssist.Hint="العنوان"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,6"/>

                        <DatePicker x:Name="dpDate"
                                    materialDesign:HintAssist.Hint="التاريخ"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                    Margin="0,6"/>

                        <TextBox x:Name="txtNotes"
                                 materialDesign:HintAssist.Hint="ملاحظات"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 AcceptsReturn="True" Height="60" Margin="0,6"/>

                        <Separator Margin="0,10"/>

                        <TextBlock Text="الملخص المالي" FontSize="14" FontWeight="Bold"
                                   Margin="0,0,0,8"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                        <Grid Margin="0,4">
                            <TextBlock Text="المجموع الكلي:" FontWeight="Bold"/>
                            <TextBlock x:Name="lblTotal" HorizontalAlignment="Left"
                                       FontSize="15" Foreground="DarkGreen"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <TextBlock Text="الخصم:" FontWeight="Bold"/>
                            <TextBox x:Name="txtDiscount"
                                     HorizontalAlignment="Left" Width="100"
                                     materialDesign:HintAssist.Hint="0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     TextChanged="TxtDiscount_TextChanged"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <TextBlock Text="الصافي:" FontWeight="Bold"/>
                            <TextBlock x:Name="lblNet" HorizontalAlignment="Left"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <TextBlock Text="المدفوع:" FontWeight="Bold"/>
                            <TextBlock x:Name="lblPaid" HorizontalAlignment="Left"
                                       Foreground="DarkGreen"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <TextBlock Text="المتبقي:" FontWeight="Bold"/>
                            <TextBlock x:Name="lblRemaining" HorizontalAlignment="Left"
                                       Foreground="Red"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Right Panel: Items + Buttons -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="56"/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card Grid.Row="0" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="تفاصيل القائمة"
                                       FontSize="15" FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <DataGrid x:Name="dgItems"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="True"
                                      CanUserDeleteRows="True"
                                      IsReadOnly="False"
                                      CellEditEnding="DgItems_CellEditEnding"
                                      materialDesign:DataGridAssist.ColumnHeaderPadding="8 6 8 6"
                                      Style="{StaticResource MaterialDesignDataGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Width="40"
                                                        Binding="{Binding ItemNumber}"
                                                        IsReadOnly="True"/>
                                    <DataGridTextColumn Header="اسم المادة" Width="*"
                                                        Binding="{Binding Name}"/>
                                    <DataGridTextColumn Header="الكمية" Width="80"
                                                        Binding="{Binding Quantity}"/>
                                    <DataGridTextColumn Header="سعر المفرد" Width="100"
                                                        Binding="{Binding UnitPrice}"/>
                                    <DataGridTextColumn Header="الإجمالي" Width="100"
                                                        Binding="{Binding TotalPrice}"
                                                        IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Bottom Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Button x:Name="btnNew" Content="قائمة جديدة" Width="130" Margin="6,0"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Click="BtnNew_Click"/>
                        <Button x:Name="btnSave" Content="حفظ القائمة" Width="130" Margin="6,0"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Click="BtnSave_Click"/>
                        <Button x:Name="btnPrint" Content="طباعة / معاينة" Width="140" Margin="6,0"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#00897B" Foreground="White"
                                Click="BtnPrint_Click"/>
                        <Button x:Name="btnDelete" Content="حذف قوائم قديمة" Width="150" Margin="6,0"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#E53935" Foreground="White"
                                Click="BtnDelete_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Window>
