<Window x:Class="KCH_New.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تغيير بيانات الدخول"
        Height="420" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Style="{StaticResource MaterialDesignWindow}">
    <StackPanel Margin="28">
        <TextBlock Text="تغيير بيانات الدخول" FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,16" HorizontalAlignment="Center"/>

        <TextBox x:Name="txtOldUser" Margin="0,6"
                 materialDesign:HintAssist.Hint="اسم المستخدم الحالي"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
        <PasswordBox x:Name="txtOldPass" Margin="0,6"
                     materialDesign:HintAssist.Hint="كلمة المرور الحالية"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"/>
        <Separator Margin="0,10"/>
        <TextBox x:Name="txtNewUser" Margin="0,6"
                 materialDesign:HintAssist.Hint="اسم المستخدم الجديد"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
        <PasswordBox x:Name="txtNewPass" Margin="0,6"
                     materialDesign:HintAssist.Hint="كلمة المرور الجديدة"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="حفظ" Width="110" Margin="8,0"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="BtnSave_Click"/>
            <Button Content="إلغاء" Width="110" Margin="8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
