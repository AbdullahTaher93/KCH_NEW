<Window x:Class="KCH_New.Views.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="إدخال المبلغ المدفوع"
        Height="240" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Style="{StaticResource MaterialDesignWindow}">
    <StackPanel Margin="28">
        <TextBlock x:Name="lblNetAmount" FontSize="15" FontWeight="Bold"
                   Margin="0,0,0,16" HorizontalAlignment="Center"/>
        <TextBox x:Name="txtPaid"
                 materialDesign:HintAssist.Hint="المبلغ الواصل من الزبون"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 FontSize="16" Margin="0,0,0,16"
                 KeyDown="TxtPaid_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="تأكيد" Width="110" Margin="8,0"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="BtnConfirm_Click"/>
            <Button Content="إلغاء" Width="110" Margin="8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
